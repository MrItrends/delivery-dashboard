# Copy to .env for local dev. Local default is SQLite.
# Dev:
DATABASE_URL="file:./dev.db"
# Prod (Vercel) — use a Postgres connection string instead, e.g. Neon:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Session signing secret — set a long random value in production.
AUTH_SECRET="change-me"
