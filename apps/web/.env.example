# =============================================================================
# Supabase — the single source of truth. Copy to .env.local for dev and set the
# same three values in Vercel → Project → Settings → Environment Variables.
# Find these in Supabase → Project Settings → API.
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Server-only (never exposed to the browser). Used for admin/seed tasks.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
